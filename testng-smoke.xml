<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Brandness Regression Suite"
       parallel="classes"
       thread-count="2">

    <listeners>
        <listener class-name="com.qa.utilities.TestListener"/>
    </listeners>

    <test name="Parallel Smoke Test">

        <classes>
            <class name="com.qa.tests.BrandnessPositiveLoginTest"/>
            <class name="com.qa.tests.LoginDataDrivenTest"/>
        </classes>

    </test>

</suite>